#!/bin/sh
#
# DYT serial camera integration for CUAV 7-Nano.
# Assumes the camera is connected to TEL2, which maps to /dev/ttyS3.
#

dyt_gimbal start -d /dev/ttyS3
dyt_guidance start

if param compare MAV_SYS_ID 1
then
	cooperative_rendezvous start -r broadcast
fi

if param compare MAV_SYS_ID 2
then
	cooperative_rendezvous start -r rendezvous -t 1 -x 0 -y 0 -z 30 -v 50
fi
